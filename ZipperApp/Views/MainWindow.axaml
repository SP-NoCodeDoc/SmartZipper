<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZipperApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="650"
        x:Class="ZipperApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SmartZipper"
        Icon="/Assets/icon.png"
        Width="750" Height="650" MinWidth="600" MinHeight="500"
        Background="#f0f1f5">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#d0d4e0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.browse">
            <Setter Property="Background" Value="#f8f9fb"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#d0d4e0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#e0e0e0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.action-primary">
            <Setter Property="Background" Value="#4a4a4a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#d0d4e0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style Selector="ProgressBar">
            <Setter Property="Background" Value="#e0e3ea"/>
            <Setter Property="Foreground" Value="#f5a623"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Height" Value="6"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="#e0e3ea" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="SmartZipper" FontSize="15" FontWeight="Bold"
                           Foreground="#222"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="12"
                           Foreground="#888" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Source / Target -->
        <StackPanel Grid.Row="1" Margin="16,12,16,8" Spacing="8">
            <Grid ColumnDefinitions="60,*,Auto">
                <TextBlock Grid.Column="0" Text="Source:" FontSize="13" Foreground="#555"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding InputPath}"
                         Watermark="Select source file or folder..." Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Browse" Classes="browse"
                        Command="{Binding BrowseInputCommand}"/>
            </Grid>
            <Grid ColumnDefinitions="60,*,Auto">
                <TextBlock Grid.Column="0" Text="Target:" FontSize="13" Foreground="#555"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding OutputDir}"
                         Watermark="Select output directory..." Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Browse" Classes="browse"
                        Command="{Binding BrowseOutputCommand}"/>
            </Grid>
        </StackPanel>

        <!-- Options Panel (replaces file list area) -->
        <Border Grid.Row="2" Background="White" BorderBrush="#e0e3ea" BorderThickness="0,1"
                Margin="16,4,16,4" CornerRadius="4" Padding="16,12">
            <ScrollViewer>
                <Grid ColumnDefinitions="*,24,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <!-- Left Column -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" FontSize="11"
                               Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox Grid.Row="1" Grid.Column="0" SelectedIndex="{Binding OutputModeIndex}"
                              HorizontalAlignment="Stretch" Margin="0,0,0,10">
                        <ComboBoxItem Content="ZIP archives"/>
                        <ComboBoxItem Content="Distribute to folders"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Split By" FontSize="11"
                               Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox Grid.Row="3" Grid.Column="0" SelectedIndex="{Binding SplitModeIndex}"
                              HorizontalAlignment="Stretch" Margin="0,0,0,10">
                        <ComboBoxItem Content="File count"/>
                        <ComboBoxItem Content="Size (MB)"/>
                    </ComboBox>

                    <StackPanel Grid.Row="4" Grid.Column="0" Spacing="6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsSplitByCount}">
                            <TextBox Width="80" Text="{Binding FilesPerArchive}" Watermark="1000"/>
                            <TextBlock Text="files each" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsSplitBySize}">
                            <TextBox Width="80" Text="{Binding MaxSizeMb}" Watermark="100"/>
                            <TextBlock Text="MB each" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox Grid.Row="5" Grid.Column="0" Content="Group into sub-folders"
                              IsChecked="{Binding UseGroupedMode}" FontSize="12"
                              IsVisible="{Binding IsSplitByCount}" Margin="0,0,0,6"
                              IsEnabled="{Binding IsZipMode}"
                              ToolTip.Tip="Organize files into numbered sub-folders inside each zip. When extracted, files will be in Folder_001/, Folder_002/, etc."/>
                    <StackPanel Grid.Row="6" Grid.Column="0" Spacing="4" IsVisible="{Binding ShowGroupedFields}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Width="60" Text="{Binding FilesPerFolder}" Watermark="10000"
                                     ToolTip.Tip="How many files to place in each sub-folder inside the zip. Example: 500 means each folder will contain up to 500 files."/>
                            <TextBlock Text="files/folder" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Width="60" Text="{Binding FoldersPerArchive}" Watermark="10"
                                     ToolTip.Tip="How many sub-folders to pack into a single zip archive. Example: 3 folders × 500 files = 1,500 files per zip."/>
                            <TextBlock Text="folders/zip" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Width="100" Text="{Binding FolderNamePrefix}" Watermark="auto"
                                     ToolTip.Tip="Name prefix for sub-folders inside the zip. Leave empty to use the source folder name. Example: 'Invoices' → Invoices_001, Invoices_002, etc."/>
                            <TextBlock Text="folder name" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right Column -->
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Compression" FontSize="11"
                               Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox Grid.Row="1" Grid.Column="2" SelectedIndex="{Binding CompressionLevelIndex}"
                              HorizontalAlignment="Stretch" IsEnabled="{Binding IsZipMode}" Margin="0,0,0,10">
                        <ComboBoxItem Content="Fastest"/>
                        <ComboBoxItem Content="Optimal"/>
                        <ComboBoxItem Content="Smallest"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="2" Text="File Pattern" FontSize="11"
                               Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding FilePattern}"
                             Watermark="*.pdf" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Settings" FontSize="11"
                               Foreground="#888" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <StackPanel Grid.Row="5" Grid.Column="2" Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Prefix:" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBox Width="100" Text="{Binding Prefix}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Threads:" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBox Width="50" Text="{Binding Parallelism}"/>
                        </StackPanel>
                        <CheckBox Content="Timestamp in names" IsChecked="{Binding IncludeTimestamp}"
                                  FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="2" Margin="0,8,0,0">
                        <TextBlock Text="Oversized files:" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                        <ComboBox SelectedIndex="{Binding OversizedHandlingIndex}"
                                  IsEnabled="{Binding IsSplitBySize}" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Own zip each"/>
                            <ComboBoxItem Content="Separate folder"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Activity Log (collapsible) -->
        <Expander Grid.Row="3" Header="▶ Activity Log" Margin="16,0,16,4" FontSize="12"
                  Foreground="#666" Padding="0">
            <ListBox ItemsSource="{Binding LogMessages}" Height="80"
                     Background="White" FontSize="11" Foreground="#666"
                     BorderBrush="#e0e3ea" BorderThickness="1" CornerRadius="4"
                     Padding="4"/>
        </Expander>

        <!-- Progress Bar + Stats -->
        <StackPanel Grid.Row="4" Margin="16,4,16,8" Spacing="4">
            <Grid ColumnDefinitions="*,Auto">
                <ProgressBar Grid.Column="0" Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent}"/>
                <TextBlock Grid.Column="1" Text="{Binding ProgressPercentText}" FontSize="11"
                           Foreground="#888" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <Grid ColumnDefinitions="*,*,*,*">
                <TextBlock Grid.Column="0" FontSize="11" Foreground="#888">
                    <Run Text="Files: "/><Run Text="{Binding FilesProgressText}"/>
                </TextBlock>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#888">
                    <Run Text="Archives: "/><Run Text="{Binding ArchivesText}"/>
                </TextBlock>
            </Grid>
        </StackPanel>

        <!-- Bottom Bar -->
        <Border Grid.Row="5" Background="White" BorderBrush="#e0e3ea" BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Free for personal use ·" FontSize="10" Foreground="#999"/>
                    <TextBlock Text="Commercial license" FontSize="10" Foreground="#5b6abf"
                               Cursor="Hand" TextDecorations="Underline"
                               PointerPressed="OnCommercialLinkClicked"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Cancel" Classes="action" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}" IsEnabled="{Binding IsRunning}"/>
                <Button Grid.Column="2" Content="Start" Classes="action-primary"
                        Command="{Binding StartCommand}" IsEnabled="{Binding !IsRunning}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
